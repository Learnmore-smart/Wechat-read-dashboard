{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/wechat-read-stats/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/wechat-read-stats/locales/(.*)",
      "dest": "public/locales/$1"
    },
    {
      "src": "/wechat-read-stats/(.*\\.(css|js|png|ico|jpg|svg|json|woff2?))",
      "dest": "public/$1"
    },
    {
      "src": "/wechat-read-stats/?$",
      "dest": "public/index.html"
    },
    {
      "src": "/wechat-read-stats/(.*)",
      "dest": "public/index.html"
    },
    {
      "src": "/(.*\\.(css|js|png|ico|jpg|svg|json|woff2?))",
      "dest": "public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
